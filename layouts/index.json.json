[
  {{- $pages := where site.RegularPages "Params.build.list" "ne" "never" -}}
  {{- range $index, $page := $pages -}}
    {{- if $index }},{{ end -}}
    {{- $content := $page.Plain | htmlUnescape | replaceRE "\\s+" " " | strings.TrimSpace -}}
    {
      "title": {{ $page.Title | jsonify }},
      "description": {{ $page.Description | default "" | jsonify }},
      "summary": {{ $page.Summary | default "" | jsonify }},
      "content": {{ $content | jsonify }},
      "permalink": {{ $page.RelPermalink | jsonify }},
      "section": {{ $page.Section | jsonify }}
    }
  {{- end -}}
]
